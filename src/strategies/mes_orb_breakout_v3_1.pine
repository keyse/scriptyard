// ============================================================================
// MES ORB Breakout v3.1 — PineScript v6
// Instrument : MES (Micro E-mini S&P 500 Futures)
// Timeframe  : 5-minute bars
// Session    : RTH only (9:30–15:55 ET)
//
// CHANGELOG FROM v3:
//   ALERT FIX 1 — Split buildAlertJson into buildEntryJson + buildExitJson.
//                 Price emitted as JSON NUMBER (no quotes), formatted "#.##".
//                 Dropped time/interval fields (TraderPost doesn't use them).
//   ALERT FIX 2 — Entry alerts now include stopPrice and takeProfit so
//                 TraderPost manages bracket exits broker-side. Faster fills,
//                 no round-trip through TV's alert engine for TP1/SL hits.
//   ALERT FIX 3 — N/A for MES: stop ratchets in this script are inline
//                 (no manage_trade() function), and the strategy.exit calls
//                 here never had embedded alert() calls. Confirmed clean.
//   SESSION-END FIX (2026-05-12) — SESSION_END exit now requires has_position
//                 AND a once-per-day latch (session_end_fired). Previously
//                 fired on every bar from 15:55 ET onward, which on ETH
//                 charts meant ~97 spurious SESSION_END_EXIT alerts/day to
//                 TraderPost regardless of position state.
//
//   NEW: alert_test_mode toggle — fires one of each payload shape on the
//        current bar so you can inspect JSON in Pipedream/webhook.site
//        before going live. Disable before trading live.
//
// ─────────────────────────────────────────────────────────────────────────────
// TRADINGVIEW ALERT SETUP — REQUIRED
//   In the alert dialog, set the condition trigger to:
//     ► "alert() function calls only"   ← NOT "Order fills and alert() function calls"
//   Set Message field to exactly:  {{strategy.order.alert_message}}
//   Paste your TraderPost webhook URL in Notifications → Webhook URL
//
//   IMPORTANT: Because TP/SL are now sent broker-side in the entry payload,
//   if TraderPost has a min-stop-distance config that conflicts with the
//   strategy's stop, you can get drift. Run alert_test_mode first and verify
//   that stopPrice / takeProfit values look correct in your webhook viewer.
//
//   NOTE on stop ratchets: when the in-script ratchet moves e?_stop mid-trade,
//   TraderPost is NOT notified — the broker-side bracket stays at the
//   original entry-time stop. Backtest results will diverge from live to
//   that extent. Sending modify-alerts on every ratchet move is a separate
//   redesign and is intentionally not included here.
// ─────────────────────────────────────────────────────────────────────────────
//
// Data period: 2026-02-20 → 2026-05-06 (53 complete days)
// Generated  : 2026-05-07; alert fixes: 2026-05-11; session-end fix: 2026-05-12
// ============================================================================
// DATA-DERIVED THRESHOLDS (all from MES analysis):
//   OR window  : 9:30–9:50 ET (4 bars: 9:30 / 9:35 / 9:40 / 9:45)
//   NARROW max : 14.25 pts (25th pctile of OR range)
//   MEDIUM max : 27.10 pts (85th pctile of OR range)
//   Trend rate : 60.4% of days break and hold direction
//   Ratchet    : 0.75× OR range → move stop to broken level (34.5% came back)
//   Opp exit   : 5 pts from opposite OR level
// ============================================================================

//@version=6
strategy(
  title                    = "MES ORB Breakout v3.1",
  shorttitle               = "MES ORB-BK v3.1",
  overlay                  = true,
  pyramiding               = 10,
  default_qty_type         = strategy.fixed,
  default_qty_value        = 1,
  initial_capital          = 10000,
  commission_type          = strategy.commission.cash_per_contract,
  commission_value         = 1.24,
  slippage                 = 1,
  calc_on_every_tick       = false,
  process_orders_on_close  = true,
  max_boxes_count          = 500,
  max_lines_count          = 500,
  max_labels_count         = 500
)

// ── SECTION A: CONSTANTS & INPUTS ────────────────────────────────────────────

// Pattern constants
string PAT_SUP = "STRONG_UP"
string PAT_SDN = "STRONG_DOWN"
string PAT_V   = "V_SHAPE"
string PAT_IV  = "INV_V"
string PAT_WU  = "WEAK_UP"
string PAT_WD  = "WEAK_DOWN"
string PAT_UNK = "UNKNOWN"

// Regime constants
string REG_N   = "NARROW"
string REG_M   = "MEDIUM"
string REG_W   = "WIDE"

// ── INPUTS ───────────────────────────────────────────────────────────────────

// SETUP — OR Window
tz_input           = input.string("America/New_York", "Timezone", group="Setup — OR Window")
or_start_hour      = input.int(9,  "OR Start Hour",   group="Setup — OR Window", minval=0, maxval=23)
or_start_min       = input.int(30, "OR Start Min",    group="Setup — OR Window", minval=0, maxval=59)
or_end_hour        = input.int(9,  "OR End Hour",     group="Setup — OR Window", minval=0, maxval=23)
or_end_min         = input.int(50, "OR End Min",      group="Setup — OR Window", minval=0, maxval=59)
session_end_hour   = input.int(15, "Session End Hour",group="Setup — OR Window", minval=0, maxval=23)
session_end_min    = input.int(55, "Session End Min", group="Setup — OR Window", minval=0, maxval=59)

// SETUP — OR Regime Width  (data-derived thresholds)
narrow_max  = input.float(14.25, "NARROW max (pts) — ≤ this = NARROW", group="Setup — OR Regime Width", step=0.25)
medium_max  = input.float(27.10, "MEDIUM max (pts) — ≤ this = MEDIUM", group="Setup — OR Regime Width", step=0.25)

// SETUP — OR Shape Filter
enable_shape_filter = input.bool(false, "Enable Shape Filter",  group="Setup — OR Shape Filter")
allow_strong_up     = input.bool(true,  "Allow STRONG_UP",      group="Setup — OR Shape Filter")
allow_strong_dn     = input.bool(true,  "Allow STRONG_DOWN",    group="Setup — OR Shape Filter")
allow_v_shape       = input.bool(true,  "Allow V_SHAPE",        group="Setup — OR Shape Filter")
allow_inv_v         = input.bool(true,  "Allow INV_V",          group="Setup — OR Shape Filter")
allow_weak_up       = input.bool(true,  "Allow WEAK_UP",        group="Setup — OR Shape Filter")
allow_weak_dn       = input.bool(true,  "Allow WEAK_DOWN",      group="Setup — OR Shape Filter")

// SETUP — Conviction Score
enable_score_filter = input.bool(false,  "Enable Score Filter",           group="Setup — Conviction Score")
min_score           = input.int(0,      "Minimum Score (0–5)",           group="Setup — Conviction Score", minval=0, maxval=5)
score_body_en       = input.bool(true,  "Score: Body Aligned",           group="Setup — Conviction Score")
score_closepos_en   = input.bool(true,  "Score: Close Position (≥0.70/≤0.30)", group="Setup — Conviction Score")
score_closepos_thr  = input.float(0.70, "Close Pos Threshold (up side)", group="Setup — Conviction Score", step=0.05)
score_pat_en        = input.bool(true,  "Score: Pattern Aligned",        group="Setup — Conviction Score")
score_width_en      = input.bool(true,  "Score: Not WIDE",               group="Setup — Conviction Score")
score_bodysize_en   = input.bool(true,  "Score: Body Size ≥ 0.30",       group="Setup — Conviction Score")
score_bodysize_thr  = input.float(0.30, "Body Size Threshold",           group="Setup — Conviction Score", step=0.05)

// SETUP — Filters (Data-Derived from backtest)
enable_thu_long_block   = input.bool(true,  "Block Thursday LONGs",                   group="Setup — Filters (Data-Derived)")
enable_tue_short_block  = input.bool(true,  "Block Tuesday SHORTs",                   group="Setup — Filters (Data-Derived)")
enable_wed_long_block   = input.bool(true,  "Block Wednesday LONGs",                  group="Setup — Filters (Data-Derived)")
enable_fri_long_block   = input.bool(true,  "Block Friday LONGs",                     group="Setup — Filters (Data-Derived)")
enable_post_e1loss_lock = input.bool(true,  "Lock day after first E1/E0 loss",        group="Setup — Filters (Data-Derived)")
enable_entry_time_cap   = input.bool(true,  "Enable Max Entry Time",                  group="Setup — Filters (Data-Derived)")
max_entry_hour          = input.int(10,     "Max Entry Hour (no entries at/after)",   group="Setup — Filters (Data-Derived)", minval=9, maxval=15)
max_entry_min           = input.int(55,      "Max Entry Min",                          group="Setup — Filters (Data-Derived)", minval=0, maxval=59)
enable_block_windows    = input.bool(false, "Enable Custom Block Windows",            group="Setup — Filters (Data-Derived)")
block_window_1_start    = input.int(1100,   "Block Window 1 Start (HHMM)",            group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)
block_window_1_end      = input.int(1230,   "Block Window 1 End (HHMM)",              group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)
block_window_2_start    = input.int(0,      "Block Window 2 Start (HHMM, 0=disabled)",group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)
block_window_2_end      = input.int(0,      "Block Window 2 End (HHMM)",              group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)
block_window_3_start    = input.int(0,      "Block Window 3 Start (HHMM, 0=disabled)",group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)
block_window_3_end      = input.int(0,      "Block Window 3 End (HHMM)",              group="Setup — Filters (Data-Derived)", minval=0, maxval=2359)

// SETUP — Visual Aids
show_entry_labels  = input.bool(true,  "Show Entry Labels",    group="Setup — Visual Aids")
show_debug_labels  = input.bool(true,  "Show Debug Labels",    group="Setup — Visual Aids")
show_composite     = input.bool(true,  "Show Composite Candle", group="Setup — Visual Aids")
show_midpoint      = input.bool(true,  "Show OR Midpoint",     group="Setup — Visual Aids")
show_pattern_label = input.bool(true,  "Show Pattern Label",   group="Setup — Visual Aids")
col_comp_bull      = input.color(color.new(#26a69a, 30), "Composite Bull Colour", group="Setup — Visual Aids")
col_comp_bear      = input.color(color.new(#ef5350, 30), "Composite Bear Colour", group="Setup — Visual Aids")
comp_wick_width    = input.int(2,     "Wick Line Width (px)", group="Setup — Visual Aids")

// SETUP — Block Labels
show_block_labels  = input.bool(true,  "Show Block Labels",   group="Setup — Block Labels")

// ENTRIES — Which to Take
enable_e0        = input.bool(true,  "Enable E0 (Break Close)",      group="Entries — Which to Take")
enable_e1        = input.bool(false, "Enable E1 (1st Retouch)",      group="Entries — Which to Take")
enable_e2        = input.bool(true,  "Enable E2 (2nd Retouch)",      group="Entries — Which to Take")
enable_e3plus    = input.bool(true, "Enable E3+ (Further Retouches)",group="Entries — Which to Take")
max_entries_per_day  = input.int(5,  "Max Entries per Day",          group="Entries — Which to Take", minval=1, maxval=5)
break_confirm_pts    = input.float(1.0, "Break Confirm (pts beyond level)",group="Entries — Which to Take", step=0.25)
retouch_touch_zone   = input.float(15.0, "Retouch Touch Zone (pts)", group="Entries — Which to Take", step=0.25)

// ENTRIES — E0 Time Filter
e0_min_hour         = input.int(10, "E0 Min Entry Hour (ET)", group="Entries — Which to Take", minval=9, maxval=11)
e0_min_min          = input.int(0,  "E0 Min Entry Min", group="Entries — Which to Take", minval=0, maxval=59)
enable_e0_time_filter = input.bool(false, "Enable E0 Time Filter", group="Entries — Which to Take")

// ENTRIES — Targets by Pattern
tp_strong_up_tp1  = input.float(2.50, "STRONG_UP  TP1 (× OR range)", group="Entries — Targets by Pattern", step=0.25)
tp_inv_v_tp1      = input.float(2.00, "INV_V      TP1 (× OR range)", group="Entries — Targets by Pattern", step=0.25)
tp_v_shape_tp1    = input.float(2.50, "V_SHAPE    TP1 (× OR range)", group="Entries — Targets by Pattern", step=0.25)
tp_weak_up_tp1    = input.float(2.50, "WEAK_UP    TP1 (× OR range)", group="Entries — Targets by Pattern", step=0.25)
tp_strong_dn_tp1  = input.float(2.00, "STRONG_DOWN TP1 (× OR range)",group="Entries — Targets by Pattern", step=0.25)
tp_weak_dn_tp1    = input.float(1.75, "WEAK_DOWN  TP1 (× OR range)", group="Entries — Targets by Pattern", step=0.25)
tp_wide_cap       = input.float(1.50, "WIDE OR target cap (× OR range)", group="Entries — Targets by Pattern", step=0.25)

// ENTRIES — WIDE Partial Exit
enable_wide_partial = input.bool(false, "WIDE: take 50% at 0.75× OR range", group="Entries — Targets by Pattern")
wide_partial_mult   = input.float(0.75, "WIDE partial exit mult (× OR range)", group="Entries — Targets by Pattern", step=0.25)

// ENTRIES — Retouch Decay
enable_retouch_decay  = input.bool(false,  "Enable Retouch Decay",        group="Entries — Retouch Decay")
e2_target_factor      = input.float(0.80, "E2 Target Factor (× TP1)",    group="Entries — Retouch Decay", step=0.05)
e3_target_pts         = input.float(10.0, "E3+ Flat Target (pts from entry)", group="Entries — Retouch Decay", step=0.25)

// ENTRIES — Retouch Count Cap
enable_retouch_modifier  = input.bool(false,  "Enable Retouch Cap",        group="Entries — Retouch Count Cap")
retouch_reduce_at        = input.int(3,      "Reduce target after N retouches", group="Entries — Retouch Count Cap", minval=1)
retouch_cap_after_n      = input.float(0.50, "Cap target multiplier (×TP1)", group="Entries — Retouch Count Cap", step=0.05)

// ENTRIES — Clean Break
enable_clean_break      = input.bool(false,  "Enable Clean Break Upgrade", group="Entries — Clean Break")
clean_break_mins        = input.int(30,     "Clean Break Window (min)",   group="Entries — Clean Break", minval=5)
clean_break_retest_zone = input.float(5.0,  "Clean Break Retest Zone (pts)", group="Entries — Clean Break", step=0.25)
clean_break_target      = input.float(3.50, "Clean Break TP (× OR range)",group="Entries — Clean Break", step=0.25)

// ENTRIES — Position Sizing
fixed_qty = input.int(1, "Contracts per Entry", group="Entries — Position Sizing", minval=1)

// ENTRIES — Weak Up Partial Exit
tp_weak_up_trail = input.bool(true, "Weak Up: trail 50% remainder after TP1", group="Entries — Targets by Pattern")

// Alerts — TradersPost
// REMINDER: In TradingView alert dialog, set condition to "alert() function calls only"
enable_traderspost_alerts = input.bool(true, "Enable TradersPost Alerts", group="Alerts — TradersPost")
traderspost_symbol        = input.string("MES", "TradersPost Symbol", group="Alerts — TradersPost")
alert_test_mode           = input.bool(false, "⚠️ ALERT TEST MODE — fires sample payloads on the last bar (disable before live trading)", group="Alerts — TradersPost")

// EXITS — Initial Stop Levels
thursday_stop_override = input.bool(false, "Thursday: use OR_MID stop", group="Exits — Initial Stop Levels")
narrow_stop_type  = input.string("OR_LOW",     "NARROW Stop Type", options=["OR_LOW","OR_MID"],  group="Exits — Initial Stop Levels")
medium_e0_stop    = input.string("OR_LOW",     "MEDIUM E0 Stop",   options=["OR_LOW","OR_MID"],  group="Exits — Initial Stop Levels")
medium_e1e2_stop  = input.string("OR_MID",     "MEDIUM E1/E2 Stop",options=["OR_LOW","OR_MID"],  group="Exits — Initial Stop Levels")
wide_stop_type    = input.string("OR_MID",     "WIDE Stop Type",   options=["OR_LOW","OR_MID"],  group="Exits — Initial Stop Levels")

// EXITS — Circuit Breaker
enable_circuit_breaker = input.bool(false, "Enable Circuit Breaker", group="Exits — Circuit Breaker")
max_consec_losses      = input.int(10, "Pause after N consecutive losses", group="Exits — Circuit Breaker", minval=1, maxval=10)
max_daily_stops        = input.int(5, "Max stop-hits per day before pause", group="Exits — Circuit Breaker", minval=1, maxval=5)

// EXITS — Stop Ratchet NARROW
narrow_be_trigger = input.float(0.75, "NARROW BE trigger (× OR range)", group="Exits — Stop Ratchet (NARROW)", step=0.25)

// EXITS — NARROW Time Stop
narrow_time_stop_mins   = input.int(999, "NARROW Time Stop (min from OR close)", group="Exits — NARROW Time Stop", minval=5)
narrow_time_stop_e0_only= input.bool(true, "Time Stop E0 only", group="Exits — NARROW Time Stop")

// EXITS — Stop Ratchet MEDIUM E0
m_e0_adj1_trigger = input.float(0.50, "MEDIUM E0: ratchet 1 trigger (× OR, → midpoint)", group="Exits — Stop Ratchet (MEDIUM E0)", step=0.25)
m_e0_adj2_trigger = input.float(0.75, "MEDIUM E0: ratchet 2 trigger (× OR, → level)",    group="Exits — Stop Ratchet (MEDIUM E0)", step=0.25)
m_e0_adj3_trigger = input.float(1.50, "MEDIUM E0: ratchet 3 trigger (× OR, trail)",       group="Exits — Stop Ratchet (MEDIUM E0)", step=0.25)

// EXITS — Stop Ratchet MEDIUM E1/E2
m_e1_adj2_trigger = input.float(0.75, "MEDIUM E1/E2: BE trigger (× OR range)", group="Exits — Stop Ratchet (MEDIUM E1/E2)", step=0.25)

// EXITS — Stop Ratchet WIDE
wide_be_trigger = input.float(0.75, "WIDE BE trigger (× OR range)", group="Exits — Stop Ratchet (WIDE)", step=0.25)

// EXITS — Opposite Level (IMPROVED)
enable_opposite_exit  = input.bool(false, "Enable Opposite Level Exit",   group="Exits — Opposite Level")
opposite_exit_zone    = input.float(5.0, "Opp Exit Zone — MINIMUM (pts)", group="Exits — Opposite Level", step=0.25)
opposite_exit_pct     = input.float(0.20, "Opp Exit Zone — % of OR range", group="Exits — Opposite Level", step=0.05)
opp_exit_fae_guard    = input.float(100.0,"Opp Exit FAE Guard ($) — suppress if FAE ≥", group="Exits — Opposite Level", step=12.5)

// EXITS — Deep Cross-Back
enable_deep_crossback_exit = input.bool(false,  "Enable Deep Cross-Back Exit",    group="Exits — Deep Cross-Back")
crossback_depth_exit       = input.float(0.40, "Cross-Back Depth Exit Threshold (× OR)", group="Exits — Deep Cross-Back", step=0.05)
crossback_dur_exit         = input.int(8,      "Cross-Back Duration Exit (bars)", group="Exits — Deep Cross-Back", minval=1)
enable_shallow_hold        = input.bool(true,  "Enable Shallow Hold Bypass",     group="Exits — Deep Cross-Back")
shallow_depth_max          = input.float(0.15, "Shallow Depth Max (× OR)",       group="Exits — Deep Cross-Back", step=0.05)
shallow_duration_max       = input.int(3,      "Shallow Duration Max (bars)",    group="Exits — Deep Cross-Back", minval=1)
deep_exit_fae_guard        = input.float(0.50, "FAE Guard: suppress exit if FAE ≥ (× OR)", group="Exits — Deep Cross-Back", step=0.05)
deep_exit_e0               = input.bool(true,  "Apply Deep Exit to E0",          group="Exits — Deep Cross-Back")
deep_exit_e1               = input.bool(true,  "Apply Deep Exit to E1",          group="Exits — Deep Cross-Back")
deep_exit_e2               = input.bool(false, "Apply Deep Exit to E2",          group="Exits — Deep Cross-Back")

// ── SECTION A: STATE VARIABLES (all var-declared at top level) ──────────────

var float or_high_v   = na
var float or_low_v    = na
var float or_mid_v    = na
var float or_open_v   = na
var float or_close_v  = na
var float or_range_v  = na

var float c1_c = na
var float c2_c = na
var float c3_c = na
var float c4_c = na

var string regime_v  = na
var string pattern_v = na
var int    score_v   = 0

var bool or_classified   = false
var bool score_calculated= false

var int  break_dir_v  = 0    // 1=up, -1=down
var int  break_bar_v  = na

var int  retouch_cnt     = 0
var int  day_entry_cnt   = 0
var bool clean_break_act = false
var int  bars_since_break= 0
var bool cb_disqualified = false
var float max_fav_exc   = 0.0

// GUARD 3 — b_in_r must be top-level var
var int  b_in_r = 0

// Retouch state variables (FIX 1 — top-level for daily reset)
var bool was_outside = true
var int  last_retouch_bar = na

var int  or_complete_bar = na

// Stop tracking (na = entry not yet open)
var float e0_stop = na
var float e1_stop = na
var float e2_stop = na
var float e3_stop = na

var float e0_tp   = na
var float e1_tp   = na
var float e2_tp   = na
var float e3_tp   = na

// Ratchet flags - properly declared at top level
var bool e0_ratchet1 = false
var bool e0_ratchet2 = false
var bool e0_ratchet3 = false
var bool e1_ratchet1 = false
var bool wide_ratchet = false

// E0 two-bar confirmation
var bool e0_first_close_ok = false

// Composite candle drawing handles
var box   comp_body = na
var line  comp_wick_up = na
var line  comp_wick_dn = na
var label comp_label_v = na

// Block tracking
var bool   trade_blocked_today = false
var bool   day_locked_e1loss = false   // Set true when first E1/E0 stops out — blocks all further entries that day
var string block_reason = ""

// Block label handles
var label block_label_v = na

// E0 time blocked tracking
var bool e0_time_blocked = false
var bool e0_attempted_today = false

// Circuit Breaker state variables
var int  consec_losses = 0
var int  daily_stop_hits = 0
var int  last_closed_count = 0

// SESSION-END FIX — once-per-day latch so SESSION_END exit + alert fires at most once
var bool session_end_fired = false

// ── SECTION B: DAILY RESET ────────────────────────────────────────────────────
is_new_day = ta.change(time("D", tz_input)) != 0

if is_new_day
    day_locked_e1loss := false
    or_high_v    := na
    or_low_v     := na
    or_mid_v     := na
    or_open_v    := na
    or_close_v   := na
    or_range_v   := na
    c1_c         := na
    c2_c         := na
    c3_c         := na
    c4_c         := na
    regime_v     := na
    pattern_v    := na
    score_v      := 0
    or_classified    := false
    score_calculated := false
    break_dir_v  := 0
    break_bar_v  := na
    retouch_cnt  := 0
    day_entry_cnt:= 0
    clean_break_act  := false
    bars_since_break := 0
    cb_disqualified  := false
    max_fav_exc      := 0.0
    b_in_r           := 0      // GUARD 3
    or_complete_bar  := na
    e0_stop := na
    e1_stop := na
    e2_stop := na
    e3_stop := na
    e0_tp   := na
    e1_tp   := na
    e2_tp   := na
    e3_tp   := na
    e0_ratchet1 := false
    e0_ratchet2 := false
    e0_ratchet3 := false
    e1_ratchet1 := false
    wide_ratchet := false
    e0_first_close_ok := false
    trade_blocked_today := false
    block_reason := ""
    day_locked_e1loss := false
    e0_time_blocked := false
    e0_attempted_today := false
    daily_stop_hits := 0
    was_outside := true       // FIX 1 — reset retouch state on new day
    last_retouch_bar := na    // FIX 1 — reset retouch bar on new day
    session_end_fired := false  // SESSION-END FIX — reset latch on new day
    // Clean up previous day's drawings
    if not na(comp_body)
        box.delete(comp_body)
        comp_body := na
    if not na(comp_wick_up)
        line.delete(comp_wick_up)
        comp_wick_up := na
    if not na(comp_wick_dn)
        line.delete(comp_wick_dn)
        comp_wick_dn := na
    if not na(comp_label_v)
        label.delete(comp_label_v)
        comp_label_v := na
    if not na(block_label_v)
        label.delete(block_label_v)
        block_label_v := na

// ── SECTION C: OR BUILDING ────────────────────────────────────────────────────
t_hour = hour(time, tz_input)
t_min  = minute(time, tz_input)

// Simpler and more robust OR window detection
// OR window: 9:30 to 9:50 ET (inclusive of start, exclusive of end)
int current_minutes = t_hour * 60 + t_min
int or_start_total  = or_start_hour * 60 + or_start_min   // 570 (9:30)
int or_end_total    = or_end_hour * 60 + or_end_min         // 570 (9:50)
int session_end_total = session_end_hour * 60 + session_end_min

bool is_or_window = current_minutes >= or_start_total and current_minutes < or_end_total
bool is_post_or    = current_minutes >= or_end_total
bool is_session_end = current_minutes >= session_end_total
bool is_rth        = current_minutes >= (9 * 60 + 30) and current_minutes < (16 * 60 + 0)

// Capture 4 specific candle closes for pattern classification
if t_hour == 9 and t_min == 30
    c1_c := close
    if na(or_open_v)
        or_open_v := open
if t_hour == 9 and t_min == 35
    c2_c := close
if t_hour == 9 and t_min == 40
    c3_c := close
if t_hour == 9 and t_min == 45
    c4_c := close

// Track OR High/Low during OR window
if is_or_window and is_rth
    or_high_v  := na(or_high_v) ? high : math.max(or_high_v, high)
    or_low_v   := na(or_low_v)  ? low  : math.min(or_low_v, low)
    or_close_v := close

// Detect OR complete (one bar after OR window ends)
is_or_complete = is_post_or and not na(or_high_v) and not na(or_low_v)

// ── SECTION D: OR CLASSIFICATION (GUARD 5) ───────────────────────────────────
if is_or_complete and not or_classified and not na(or_high_v) and not na(or_low_v)
    or_range_v := or_high_v - or_low_v
    or_mid_v   := (or_high_v + or_low_v) / 2.0
    
    // Regime
    if or_range_v <= narrow_max
        regime_v := REG_N
    else if or_range_v <= medium_max
        regime_v := REG_M
    else
        regime_v := REG_W
    
    // Pattern (requires all 4 closes)
    if not na(c1_c) and not na(c2_c) and not na(c3_c) and not na(c4_c)
        if c1_c < c2_c and c2_c < c3_c and c3_c < c4_c
            pattern_v := PAT_SUP
        else if c1_c > c2_c and c2_c > c3_c and c3_c > c4_c
            pattern_v := PAT_SDN
        else if c2_c < c1_c and c4_c > c2_c
            pattern_v := PAT_V
        else if c2_c > c1_c and c4_c < c2_c
            pattern_v := PAT_IV
        else if c4_c > c1_c
            pattern_v := PAT_WU
        else if c4_c < c1_c
            pattern_v := PAT_WD
        else
            pattern_v := PAT_UNK
    else
        pattern_v := PAT_UNK
    
    or_complete_bar := bar_index
    or_classified   := true

// ── SECTION E: BREAK DETECTION ────────────────────────────────────────────────
if is_post_or and break_dir_v == 0 and not na(or_high_v) and is_rth
    if high > or_high_v + break_confirm_pts
        break_dir_v := 1
        break_bar_v := bar_index
    else if low < or_low_v - break_confirm_pts
        break_dir_v := -1
        break_bar_v := bar_index

// ── SECTION F: CONVICTION SCORE (GUARD 2) ─────────────────────────────────────
bull_body_v  = not na(or_close_v) and not na(or_open_v) and or_close_v > or_open_v
body_size_v  = not na(or_range_v) and or_range_v > 0 ? math.abs(or_close_v - or_open_v) / or_range_v : 0.0
close_pos_v  = not na(or_range_v) and or_range_v > 0 ? (or_close_v - or_low_v) / or_range_v : 0.5

if break_dir_v != 0 and not score_calculated and not na(or_range_v)
    body_aligned = (break_dir_v == 1 and bull_body_v) or (break_dir_v == -1 and not bull_body_v)
    
    s_body      = score_body_en    and body_aligned ? 1 : 0
    s_closepos  = score_closepos_en and
                  ((break_dir_v == 1 and close_pos_v >= score_closepos_thr) or
                   (break_dir_v == -1 and close_pos_v <= 1.0 - score_closepos_thr)) ? 1 : 0
    
    bool pat_up = pattern_v == PAT_V or pattern_v == PAT_WU or pattern_v == PAT_SUP
    bool pat_dn = pattern_v == PAT_IV or pattern_v == PAT_WD or pattern_v == PAT_SDN
    s_pat       = score_pat_en and ((break_dir_v == 1 and pat_up) or (break_dir_v == -1 and pat_dn)) ? 1 : 0
    s_width     = score_width_en and (regime_v == REG_N or regime_v == REG_M) ? 1 : 0
    s_bodysize  = score_bodysize_en and body_size_v >= score_bodysize_thr ? 1 : 0
    
    score_v          := s_body + s_closepos + s_pat + s_width + s_bodysize
    score_calculated := true

// ── SECTION G: SHAPE & SCORE FILTERS ─────────────────────────────────────────
bool filter_ok = true
if enable_score_filter and break_dir_v != 0
    if score_v < min_score
        filter_ok := false

if enable_shape_filter and not na(pattern_v)
    if (pattern_v == PAT_SUP and not allow_strong_up) or
       (pattern_v == PAT_SDN and not allow_strong_dn) or
       (pattern_v == PAT_V   and not allow_v_shape) or
       (pattern_v == PAT_IV  and not allow_inv_v) or
       (pattern_v == PAT_WU  and not allow_weak_up) or
       (pattern_v == PAT_WD  and not allow_weak_dn)
        filter_ok := false

// ── SECTION G2: CIRCUIT BREAKER TRACKING ─────────────────────────────────────
// Track losses BEFORE filter check
if strategy.closedtrades > last_closed_count
    float last_pnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if last_pnl < 0
        consec_losses += 1
        daily_stop_hits += 1
    else if last_pnl > 0
        consec_losses := 0

    // Lock day after first E1/E0 loss
    if enable_post_e1loss_lock and last_pnl < 0
        string last_entry_id = strategy.closedtrades.entry_id(strategy.closedtrades - 1)
        if last_entry_id == "E0" or last_entry_id == "E1"
            day_locked_e1loss := true

    last_closed_count := strategy.closedtrades

// Circuit breaker filter
if enable_circuit_breaker
    if consec_losses >= max_consec_losses or daily_stop_hits >= max_daily_stops
        filter_ok := false

// ── SECTION H: CLEAN BREAK TRACKING (GUARD 6) ────────────────────────────────
if break_dir_v != 0 and not clean_break_act and bar_index > break_bar_v  // GUARD 6
    bars_since_break += 1
    
    if break_dir_v == 1
        if low < or_high_v - clean_break_retest_zone
            cb_disqualified := true
    else
        if high > or_low_v + clean_break_retest_zone
            cb_disqualified := true
    
    if bars_since_break >= (clean_break_mins / 5) and not cb_disqualified
        clean_break_act := true

// ── SECTION I: MAX FAVORABLE EXCURSION (GUARD 1) ─────────────────────────────
if break_dir_v != 0
    float curr_exc = break_dir_v == 1 ? high - or_high_v : or_low_v - low
    max_fav_exc := math.max(max_fav_exc, curr_exc)  // GUARD 1 — running max

// ── SECTION J: STOP & TARGET FUNCTIONS ────────────────────────────────────────

// Returns true if entry is allowed at the current bar based on data-derived filters
is_entry_allowed() =>
    bool ok = true
    int  hhmm = t_hour * 100 + t_min

    // Thursday long block
    if enable_thu_long_block and dayofweek(time, tz_input) == dayofweek.thursday and break_dir_v == 1
        ok := false

    // Tuesday short block
    if enable_tue_short_block and dayofweek(time, tz_input) == dayofweek.tuesday and break_dir_v == -1
        ok := false

    // Wednesday long block (marginal performer, +$6 / 56 trades)
    if enable_wed_long_block and dayofweek(time, tz_input) == dayofweek.wednesday and break_dir_v == 1
        ok := false

    // Friday long block (negative performer, -$88 / 57 trades)
    if enable_fri_long_block and dayofweek(time, tz_input) == dayofweek.friday and break_dir_v == 1
        ok := false

    // Day locked after E1/E0 loss
    if enable_post_e1loss_lock and day_locked_e1loss
        ok := false

    // Max entry time
    if enable_entry_time_cap and current_minutes >= (max_entry_hour * 60 + max_entry_min)
        ok := false

    // Custom block windows (HHMM format)
    if enable_block_windows
        if block_window_1_start > 0 and hhmm >= block_window_1_start and hhmm < block_window_1_end
            ok := false
        if block_window_2_start > 0 and hhmm >= block_window_2_start and hhmm < block_window_2_end
            ok := false
        if block_window_3_start > 0 and hhmm >= block_window_3_start and hhmm < block_window_3_end
            ok := false

    ok

get_base_stop(etype) =>
    float s = na
    // Thursday stop override - check FIRST
    bool is_thu = dayofweek(time, tz_input) == dayofweek.thursday
    if thursday_stop_override and is_thu and break_dir_v != 0 and not na(or_mid_v)
        s := break_dir_v == 1 ? or_mid_v : or_mid_v
    else if not na(or_high_v) and not na(or_low_v) and break_dir_v != 0
        if pattern_v == PAT_SUP or pattern_v == PAT_SDN
            // Strong directional: always use full OR level
            s := break_dir_v == 1 ? or_low_v : or_high_v
        else if regime_v == REG_N
            if narrow_stop_type == "OR_MID"
                s := break_dir_v == 1 ? or_mid_v : or_mid_v
            else
                s := break_dir_v == 1 ? or_low_v : or_high_v
        else if regime_v == REG_M
            if etype == 0
                if medium_e0_stop == "OR_MID"
                    s := break_dir_v == 1 ? or_mid_v : or_mid_v
                else
                    s := break_dir_v == 1 ? or_low_v : or_high_v
            else
                if medium_e1e2_stop == "OR_LOW"
                    s := break_dir_v == 1 ? or_low_v : or_high_v
                else
                    s := break_dir_v == 1 ? or_mid_v : or_mid_v
        else  // WIDE
            if wide_stop_type == "OR_LOW"
                s := break_dir_v == 1 ? or_low_v : or_high_v
            else
                s := break_dir_v == 1 ? or_mid_v : or_mid_v
    s

get_base_tp(etype) =>
    float tp = na
    if not na(or_range_v) and or_range_v > 0 and break_dir_v != 0
        float mult = switch pattern_v
            PAT_SUP => tp_strong_up_tp1
            PAT_SDN => tp_strong_dn_tp1
            PAT_V   => tp_v_shape_tp1
            PAT_IV  => tp_inv_v_tp1
            PAT_WU  => tp_weak_up_tp1
            PAT_WD  => tp_weak_dn_tp1
            =>         2.0  // fallback

        // Retouch decay
        if enable_retouch_decay
            if etype == 2
                mult *= e2_target_factor
            else if etype >= 3
                // flat pts override applied below
                mult := 0.0

        // Retouch count cap
        if enable_retouch_modifier and retouch_cnt >= retouch_reduce_at
            mult *= retouch_cap_after_n

        // Clean break upgrade
        if enable_clean_break and clean_break_act and etype <= 1
            mult := math.max(mult, clean_break_target)

        // WIDE cap
        if regime_v == REG_W
            mult := math.min(mult, tp_wide_cap)

        float tp_pts = 0.0
        if etype >= 3
            tp_pts := e3_target_pts
        else
            tp_pts := mult * or_range_v

        tp := break_dir_v == 1 ? or_high_v + tp_pts : or_low_v - tp_pts
    tp

// ─────────────────────────────────────────────────────────────────────────────
// TRADERSPOST ALERT HELPERS (ALERT FIX 1 + FIX 2)
//
// FIX 1: price is a JSON number (no surrounding quotes), formatted "#.##".
//        Removed time and interval fields — TraderPost does not use them.
//
// FIX 2: buildEntryJson includes stopPrice and takeProfit so TraderPost can
//        bracket the order broker-side. The strategy's strategy.exit() calls
//        still manage exits on the TradingView side for backtesting accuracy,
//        but TP1/SL hits do NOT need to round-trip through a fresh alert.
//        Only the four close_all() exit reasons still send exit alerts.
// ─────────────────────────────────────────────────────────────────────────────

// Basic exit alert — action is always "exit"
buildExitJson(series string signalId) =>
    '{"ticker":"' + traderspost_symbol + '","action":"exit","price":' + str.tostring(close, "#.##") + ',"signalId":"' + signalId + '"}'

// Entry alert — includes stop and TP so TraderPost can bracket the order
buildEntryJson(series string action, series string signalId, float stopPrice, float tpPrice) =>
    '{"ticker":"' + traderspost_symbol + '","action":"' + action + '","price":' + str.tostring(close, "#.##") + ',"stopPrice":' + str.tostring(stopPrice, "#.##") + ',"takeProfit":' + str.tostring(tpPrice, "#.##") + ',"signalId":"' + signalId + '"}'

// ── SECTION K: ENTRY LOGIC ────────────────────────────────────────────────────

// E0 time filter computation
bool e0_time_ok = not enable_e0_time_filter or (t_hour * 60 + t_min) >= (e0_min_hour * 60 + e0_min_min)

// FIX: Lock day immediately if E1/E0 stop has been touched/breached on this bar
// This runs BEFORE entry logic, preventing same-bar stacking after a loss
if enable_post_e1loss_lock and not day_locked_e1loss
    if not na(e0_stop) and break_dir_v != 0
        if (break_dir_v == 1 and low <= e0_stop) or (break_dir_v == -1 and high >= e0_stop)
            day_locked_e1loss := true
    if not na(e1_stop) and break_dir_v != 0
        if (break_dir_v == 1 and low <= e1_stop) or (break_dir_v == -1 and high >= e1_stop)
            day_locked_e1loss := true

// E0 two-bar confirmation — Step 1: First confirming close
if is_post_or and break_dir_v != 0 and not e0_first_close_ok and not na(or_high_v)
    if break_dir_v == 1 and close > or_high_v + break_confirm_pts
        e0_first_close_ok := true
    else if break_dir_v == -1 and close < or_low_v - break_confirm_pts
        e0_first_close_ok := true

// E0 — entry attempt on the bar immediately after break confirmation
// Only attempt ONCE per day, check time filter at moment of attempt
if enable_e0 and e0_first_close_ok and bar_index == break_bar_v + 1 and not e0_attempted_today and day_entry_cnt < max_entries_per_day and filter_ok and is_entry_allowed() and na(e0_stop)
    // Entry CAN be attempted on this bar
    if not e0_time_ok and enable_e0_time_filter
        // Time filter blocks - set reason ONCE
        if not e0_attempted_today
            e0_attempted_today := true
            trade_blocked_today := true
            block_reason := "TIME_FILTER"
    else
        // Time filter passes - attempt entry
        e0_stop := get_base_stop(0)
        e0_tp   := get_base_tp(0)
        if not na(e0_stop) and not na(e0_tp)
            strategy.entry("E0", break_dir_v == 1 ? strategy.long : strategy.short, qty=fixed_qty)
            day_entry_cnt += 1
            e0_attempted_today := true
            if show_entry_labels
                label.new(bar_index + 0, break_dir_v == 1 ? low - 8 : high + 8,
                          "E0", style=break_dir_v == 1 ? label.style_label_up : label.style_label_down, color=color.blue, textcolor=color.white, size=size.normal)
            if enable_traderspost_alerts
                // ALERT FIX 2: entry payload now carries stopPrice + takeProfit
                alert(buildEntryJson(break_dir_v == 1 ? "buy" : "sell", "E0_ENTRY", e0_stop, e0_tp), alert.freq_once_per_bar)
else if enable_e0 and break_dir_v != 0 and bar_index == break_bar_v
    // Track blocked entry reasons for E0 at break bar (before entry attempt)
    if not filter_ok
        block_reason := "FILTER"
        trade_blocked_today := true
    else if day_entry_cnt >= max_entries_per_day
        block_reason := "MAX_ENTRIES"
        trade_blocked_today := true
    else if not na(e0_stop)
        block_reason := "DUP_ENTRY"
        trade_blocked_today := true

// Debug label for blocked E0 - show on bars after break_bar_v when entry was blocked
if enable_e0 and break_dir_v != 0 and break_bar_v > 0 and bar_index > break_bar_v and na(e0_stop) and trade_blocked_today and not na(block_reason) and block_reason != "" and show_debug_labels
    label.new(bar_index + 3, break_dir_v == 1 ? high + 15 : low - 15, "NO E0: " + block_reason,
              style=break_dir_v == 1 ? label.style_label_down : label.style_label_up, color=color.orange, textcolor=color.white, size=size.small)

// Debug label for E0 time filter block
if enable_e0 and e0_time_blocked and show_debug_labels
    label.new(bar_index, break_dir_v == 1 ? high + 30 : low - 30, "E0: " + block_reason,
              style=break_dir_v == 1 ? label.style_label_down : label.style_label_up, color=color.purple, textcolor=color.white, size=size.small)

// Retouch detection for E1/E2/E3+

if break_dir_v != 0 and bar_index > break_bar_v and is_post_or and is_rth
    bool in_touch_zone = false
    bool back_outside  = false
    
    if break_dir_v == 1
        in_touch_zone := low  <= or_high_v + retouch_touch_zone and low  >= or_high_v - retouch_touch_zone
        back_outside  := close > or_high_v
    else
        in_touch_zone := high >= or_low_v  - retouch_touch_zone and high <= or_low_v  + retouch_touch_zone
        back_outside  := close < or_low_v
    
    if in_touch_zone and was_outside
        was_outside := false
    else if back_outside and not was_outside
        was_outside    := true
        retouch_cnt    += 1
        last_retouch_bar := bar_index
        
        // E1 entry
        if enable_e1 and retouch_cnt == 1 and day_entry_cnt < max_entries_per_day and filter_ok and is_entry_allowed() and na(e1_stop)
            e1_stop := get_base_stop(1)
            e1_tp   := get_base_tp(1)
            if not na(e1_stop) and not na(e1_tp)
                strategy.entry("E1", break_dir_v == 1 ? strategy.long : strategy.short, qty=fixed_qty)
                day_entry_cnt += 1
                if show_entry_labels
                    label.new(bar_index, break_dir_v == 1 ? low - 18 : high + 18,
                              "E1", style=break_dir_v == 1 ? label.style_label_up : label.style_label_down, color=color.green, textcolor=color.white, size=size.normal)
                if enable_traderspost_alerts
                    // ALERT FIX 2: entry payload now carries stopPrice + takeProfit
                    alert(buildEntryJson(break_dir_v == 1 ? "buy" : "sell", "E1_ENTRY", e1_stop, e1_tp), alert.freq_once_per_bar)
        
        // E2 entry
        else if enable_e2 and retouch_cnt == 2 and day_entry_cnt < max_entries_per_day and filter_ok and is_entry_allowed() and na(e2_stop)
            e2_stop := get_base_stop(2)
            e2_tp   := get_base_tp(2)
            if not na(e2_stop) and not na(e2_tp)
                strategy.entry("E2", break_dir_v == 1 ? strategy.long : strategy.short, qty=fixed_qty)
                day_entry_cnt += 1
                if show_entry_labels
                    label.new(bar_index + 6, break_dir_v == 1 ? low - 28 : high + 28,
                              "E2", style=break_dir_v == 1 ? label.style_label_up : label.style_label_down, color=color.teal, textcolor=color.white, size=size.normal)
                if enable_traderspost_alerts
                    // ALERT FIX 2: entry payload now carries stopPrice + takeProfit
                    alert(buildEntryJson(break_dir_v == 1 ? "buy" : "sell", "E2_ENTRY", e2_stop, e2_tp), alert.freq_once_per_bar)
        
        // E3+ entry
        else if enable_e3plus and retouch_cnt >= 3 and day_entry_cnt < max_entries_per_day and filter_ok and is_entry_allowed() and na(e3_stop)
            e3_stop := get_base_stop(3)
            e3_tp   := get_base_tp(3)
            if not na(e3_stop) and not na(e3_tp)
                strategy.entry("E3", break_dir_v == 1 ? strategy.long : strategy.short, qty=fixed_qty)
                day_entry_cnt += 1
                if show_entry_labels
                    label.new(bar_index + 9, break_dir_v == 1 ? low - 38 : high + 38,
                              "E3+", style=break_dir_v == 1 ? label.style_label_up : label.style_label_down, color=color.orange, textcolor=color.white, size=size.normal)
                if enable_traderspost_alerts
                    // ALERT FIX 2: entry payload now carries stopPrice + takeProfit
                    alert(buildEntryJson(break_dir_v == 1 ? "buy" : "sell", "E3_ENTRY", e3_stop, e3_tp), alert.freq_once_per_bar)

// ── SECTION L: STOP RATCHET & TARGET MANAGEMENT (FIXED - PERSISTENT VARS) ─────
// NOTE: No alert() calls inside this section. TP1/SL hits managed by TraderPost
//       broker-side from the bracket info sent in the entry alert (FIX 2).
//       In-script ratchet moves DO update e?_stop / strategy.exit() but do NOT
//       notify TraderPost — backtest results will diverge from live to that
//       extent. See top-of-file note.

// E0 Stop Ratchet - UPDATE PERSISTENT VAR DIRECTLY
if not na(e0_stop) and not na(e0_tp) and break_dir_v != 0 and not na(or_range_v)
    float fav   = max_fav_exc
    float or_r  = or_range_v
    float level = break_dir_v == 1 ? or_high_v : or_low_v
    float mid   = or_mid_v
    
    if regime_v == REG_M
        // Descending order — highest trigger first
        if not e0_ratchet3 and fav >= m_e0_adj3_trigger * or_r
            // Trailing: advance stop proportionally above/below level
            float trail_delta = fav - m_e0_adj3_trigger * or_r
            e0_stop := break_dir_v == 1 ? level + trail_delta : level - trail_delta
            e0_ratchet3 := true
        else if not e0_ratchet2 and fav >= m_e0_adj2_trigger * or_r
            e0_stop := level            // UPDATE PERSISTENT VAR (breakeven)
            e0_ratchet2 := true
        else if not e0_ratchet1 and fav >= m_e0_adj1_trigger * or_r
            e0_stop := mid              // UPDATE PERSISTENT VAR (midpoint)
            e0_ratchet1 := true
    else if regime_v == REG_N
        if not e0_ratchet1 and fav >= narrow_be_trigger * or_r
            e0_stop := level            // UPDATE PERSISTENT VAR
            e0_ratchet1 := true
    else if regime_v == REG_W
        if not wide_ratchet and fav >= wide_be_trigger * or_r
            e0_stop := level            // UPDATE PERSISTENT VAR
            wide_ratchet := true
    
    // WIDE partial exit
    if regime_v == REG_W and enable_wide_partial and not na(or_range_v)
        float wide_partial_price = break_dir_v == 1 ? or_high_v + wide_partial_mult * or_range_v : or_low_v - wide_partial_mult * or_range_v
        strategy.exit("E0_wide_partial", from_entry="E0", limit=wide_partial_price, qty_percent=50, comment_profit="E0_WIDE_PARTIAL")
    
    // Exit calls use updated e0_stop (the persistent var)
    if pattern_v == PAT_WU and tp_weak_up_trail and break_dir_v == 1
        strategy.exit("E0_TP1", from_entry="E0", limit=e0_tp, qty_percent=50, comment_profit="E0_PARTIAL")
        strategy.exit("E0_Trail", from_entry="E0", stop=level, comment_profit="E0_TRAIL_HIT", comment_loss="E0_TRAIL_STOP")
    else
        strategy.exit("E0_exit", from_entry="E0", stop=e0_stop, limit=e0_tp, comment_profit="E0_TARGET", comment_loss="E0_STOP")

// E1 Stop Ratchet - UPDATE PERSISTENT VAR DIRECTLY
if not na(e1_stop) and not na(e1_tp) and break_dir_v != 0 and not na(or_range_v)
    float fav1   = max_fav_exc
    float or_r1  = or_range_v
    float level1 = break_dir_v == 1 ? or_high_v : or_low_v
    
    if regime_v == REG_M
        if not e1_ratchet1 and fav1 >= m_e1_adj2_trigger * or_r1
            e1_stop := level1            // UPDATE PERSISTENT VAR
            e1_ratchet1 := true
    
    // WIDE partial exit
    if regime_v == REG_W and enable_wide_partial and not na(or_range_v)
        float wide_partial_price1 = break_dir_v == 1 ? or_high_v + wide_partial_mult * or_range_v : or_low_v - wide_partial_mult * or_range_v
        strategy.exit("E1_wide_partial", from_entry="E1", limit=wide_partial_price1, qty_percent=50, comment_profit="E1_WIDE_PARTIAL")
    
    // Exit with e1_stop (persistent var)
    if pattern_v == PAT_WU and tp_weak_up_trail and break_dir_v == 1
        strategy.exit("E1_TP1", from_entry="E1", limit=e1_tp, qty_percent=50, comment_profit="E1_PARTIAL")
        strategy.exit("E1_Trail", from_entry="E1", stop=level1, comment_profit="E1_TRAIL_HIT", comment_loss="E1_TRAIL_STOP")
    else
        strategy.exit("E1_exit", from_entry="E1", stop=e1_stop, limit=e1_tp, comment_profit="E1_TARGET", comment_loss="E1_STOP")

// E2 Stop Ratchet - UPDATE PERSISTENT VAR DIRECTLY
if not na(e2_stop) and not na(e2_tp) and break_dir_v != 0 and not na(or_range_v)
    float fav2   = max_fav_exc
    float or_r2  = or_range_v
    float level2 = break_dir_v == 1 ? or_high_v : or_low_v
    
    if regime_v == REG_M
        if not e1_ratchet1 and fav2 >= m_e1_adj2_trigger * or_r2
            e2_stop := level2            // UPDATE PERSISTENT VAR
            e1_ratchet1 := true
    
    // WIDE partial exit
    if regime_v == REG_W and enable_wide_partial and not na(or_range_v)
        float wide_partial_price2 = break_dir_v == 1 ? or_high_v + wide_partial_mult * or_range_v : or_low_v - wide_partial_mult * or_range_v
        strategy.exit("E2_wide_partial", from_entry="E2", limit=wide_partial_price2, qty_percent=50, comment_profit="E2_WIDE_PARTIAL")
    
    // Exit with e2_stop (persistent var)
    if pattern_v == PAT_WU and tp_weak_up_trail and break_dir_v == 1
        strategy.exit("E2_TP1", from_entry="E2", limit=e2_tp, qty_percent=50, comment_profit="E2_PARTIAL")
        strategy.exit("E2_Trail", from_entry="E2", stop=level2, comment_profit="E2_TRAIL_HIT", comment_loss="E2_TRAIL_STOP")
    else
        strategy.exit("E2_exit", from_entry="E2", stop=e2_stop, limit=e2_tp, comment_profit="E2_TARGET", comment_loss="E2_STOP")

// E3 Stop Ratchet - UPDATE PERSISTENT VAR DIRECTLY
if not na(e3_stop) and not na(e3_tp) and break_dir_v != 0 and not na(or_range_v)
    float level3 = break_dir_v == 1 ? or_high_v : or_low_v
    
    // WIDE partial exit
    if regime_v == REG_W and enable_wide_partial and not na(or_range_v)
        float wide_partial_price3 = break_dir_v == 1 ? or_high_v + wide_partial_mult * or_range_v : or_low_v - wide_partial_mult * or_range_v
        strategy.exit("E3_wide_partial", from_entry="E3", limit=wide_partial_price3, qty_percent=50, comment_profit="E3_WIDE_PARTIAL")
    
    // Exit with e3_stop (persistent var)
    if pattern_v == PAT_WU and tp_weak_up_trail and break_dir_v == 1
        strategy.exit("E3_TP1", from_entry="E3", limit=e3_tp, qty_percent=50, comment_profit="E3_PARTIAL")
        strategy.exit("E3_Trail", from_entry="E3", stop=level3, comment_profit="E3_TRAIL_HIT", comment_loss="E3_TRAIL_STOP")
    else
        strategy.exit("E3_exit", from_entry="E3", stop=e3_stop, limit=e3_tp, comment_profit="E3_TARGET", comment_loss="E3_STOP")

// ── SECTION M: OVERRIDE EXITS ─────────────────────────────────────────────────
bool has_position = strategy.position_size != 0

// 1. NARROW TIME STOP
if has_position and regime_v == REG_N
    bool e0_only_pass = narrow_time_stop_e0_only ? na(e1_stop) : true
    int  bars_in_session = not na(or_complete_bar) ? bar_index - or_complete_bar : 0
    if e0_only_pass and bars_in_session >= (narrow_time_stop_mins / 5)
        float crossed_back_price = break_dir_v == 1 ? or_high_v : or_low_v
        if (break_dir_v == 1 and close < crossed_back_price) or (break_dir_v == -1 and close > crossed_back_price)
            strategy.close_all(comment="TIME_STOP")
            if enable_traderspost_alerts
                alert(buildExitJson("TIME_STOP_EXIT"), alert.freq_once_per_bar)

// 2. OPPOSITE LEVEL EXIT (IMPROVED — proportional zone + FAE guard)
if has_position and enable_opposite_exit and break_dir_v != 0 and not na(or_high_v) and not na(or_range_v)
    float dyn_zone = math.max(opposite_exit_zone, or_range_v * opposite_exit_pct)
    bool  fae_ok   = opp_exit_fae_guard <= 0 or max_fav_exc < opp_exit_fae_guard  // suppress if FAE too high
    if fae_ok
        if break_dir_v == 1 and low <= or_low_v + dyn_zone
            strategy.close_all(comment="OPP_EXIT")
            if enable_traderspost_alerts
                alert(buildExitJson("OPPOSITE_LEVEL_EXIT"), alert.freq_once_per_bar)
        else if break_dir_v == -1 and high >= or_high_v - dyn_zone
            strategy.close_all(comment="OPP_EXIT")
            if enable_traderspost_alerts
                alert(buildExitJson("OPPOSITE_LEVEL_EXIT"), alert.freq_once_per_bar)

// 3. DEEP CROSS-BACK EXIT
if has_position and enable_deep_crossback_exit and break_dir_v != 0 and not na(or_range_v) and or_range_v > 0
    bool in_range = false
    float dep = 0.0
    
    if break_dir_v == 1
        in_range := close < or_high_v
        dep      := (or_high_v - close) / or_range_v
    else
        in_range := close > or_low_v
        dep      := (close - or_low_v) / or_range_v
    
    if in_range
        b_in_r += 1
    else
        b_in_r := 0
    
    bool sha = enable_shallow_hold and dep < shallow_depth_max and b_in_r < shallow_duration_max
    bool fae_prot = deep_exit_fae_guard > 0 and max_fav_exc >= deep_exit_fae_guard * or_range_v
    bool entry_allows = (not na(e0_stop) and deep_exit_e0) or (not na(e1_stop) and deep_exit_e1) or (not na(e2_stop) and deep_exit_e2)
    
    if in_range and b_in_r > crossback_dur_exit and dep > crossback_depth_exit and not sha and not fae_prot and entry_allows
        strategy.close_all(comment="DEEP_CB_EXIT")
        if enable_traderspost_alerts
            alert(buildExitJson("DEEP_EXIT"), alert.freq_once_per_bar)

// 4. SESSION END
// SESSION-END FIX (2026-05-12) — fires at most once per day, only when a
// position is open. Previously fired on every bar from 15:55 ET onward; on
// ETH charts that meant ~97 spurious SESSION_END_EXIT alerts per day.
if is_session_end and has_position and not session_end_fired
    strategy.close_all(comment="SESSION_END")
    session_end_fired := true
    if enable_traderspost_alerts
        alert(buildExitJson("SESSION_END_EXIT"), alert.freq_once_per_bar)

// ── SECTION N: VISUALISATION ───────────────────────────────────────────────────

// OR High/Low lines
plot(or_high_v, "OR High", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(or_low_v,  "OR Low",  color=color.new(color.red,   0), style=plot.style_linebr, linewidth=2)

// OR Midpoint
plot(show_midpoint and not na(or_mid_v) ? or_mid_v : na, "OR Mid",
     color=color.new(color.gray, 40), style=plot.style_linebr, linewidth=1)

// Composite candle (draws once per day when OR is classified)
// Improved version with better positioning, dotted border, midpoint line, and wick % labels
if barstate.islastconfirmedhistory and show_composite and or_classified and not or_classified[1] and not na(or_high_v) and not na(or_open_v)
    bool is_bull = or_close_v >= or_open_v
    float body_top    = math.max(or_open_v, or_close_v)
    float body_bottom = math.min(or_open_v, or_close_v)
    color body_col = is_bull ? col_comp_bull : col_comp_bear
    color wick_col = is_bull ? color.new(#26a69a, 0) : color.new(#ef5350, 0)
    
    // Position: 5 bars to the left of current bar
    int x1     = bar_index - 5
    int x2     = bar_index - 1
    int x_mid  = int((x1 + x2) / 2)
    
    // Body box with grey dotted border
    comp_body := box.new(
        left         = x1,
        top          = body_top,
        right        = x2,
        bottom       = body_bottom,
        bgcolor      = body_col,
        border_color = color.gray,
        border_width = 1,
        border_style = line.style_dotted
    )
    
    // Upper wick (body_top → OR High)
    if or_high_v > body_top
        comp_wick_up := line.new(
            x1    = x_mid, y1 = body_top,
            x2    = x_mid, y2 = or_high_v,
            color = wick_col,
            width = comp_wick_width
        )
    
    // Lower wick (body_bot → OR Low)
    if or_low_v < body_bottom
        comp_wick_dn := line.new(
            x1    = x_mid, y1 = body_bottom,
            x2    = x_mid, y2 = or_low_v,
            color = wick_col,
            width = comp_wick_width
        )
    
    // Midpoint tick — dotted white line across body centre
    float body_mid_price = (body_top + body_bottom) / 2
    line.new(
        x1    = x1, y1 = body_mid_price,
        x2    = x2, y2 = body_mid_price,
        color = color.new(color.white, 70),
        width = 1,
        style = line.style_dotted
    )
    
    // Calculate wick percentages
    float upper_wick = or_high_v - body_top
    float lower_wick = body_bottom - or_low_v
    float upper_pct = or_range_v > 0 ? (upper_wick / or_range_v) * 100 : 0.0
    float lower_pct = or_range_v > 0 ? (lower_wick / or_range_v) * 100 : 0.0
    
    // Determine trade bias based on pattern
    string trade_bias = switch pattern_v
        PAT_SUP => "LONG"
        PAT_SDN => "SHORT"
        PAT_V   => "LONG"
        PAT_IV  => "SHORT"
        PAT_WU  => "LONG (cautious)"
        PAT_WD  => "SHORT (fade)"
        => "?"
    
    // Pattern label with detailed info
    if show_pattern_label
        string pat_short = switch pattern_v
            PAT_V   => "V-Shape"
            PAT_IV  => "Inv-V"
            PAT_WU  => "Weak Up"
            PAT_WD  => "Weak Down"
            PAT_SUP => "Strong Up"
            PAT_SDN => "Strong Down"
            => "?"
        
        string regime_abbr = regime_v == REG_N ? "NARROW" : regime_v == REG_M ? "MEDIUM" : "WIDE"
        string lbl_txt = pat_short + "\n" + regime_abbr + " " + trade_bias + "\n" + 
                         str.tostring(math.round(or_range_v)) + "pts | " +
                         "U=" + str.tostring(math.round(upper_pct)) + "% L=" + str.tostring(math.round(lower_pct)) + "%"
        
        comp_label_v := label.new(
            x              = x_mid,
            y              = is_bull ? or_high_v + 80 : or_low_v - 80,
            text           = lbl_txt,
            color          = color.rgb(100, 181, 246),
            textcolor      = color.white,
            style          = is_bull ? label.style_label_down : label.style_label_up,
            size           = size.small,
            text_font_family = font.family_default,
            text_formatting   = text.format_bold
        )
    
    // Upper wick percentage label (▲)
    if upper_wick > 0
        label.new(
            x              = x_mid,
            y              = or_high_v + 25,
            text           = "▲" + str.tostring(math.round(upper_pct)) + "%",
            color          = color.new(color.gray, 70),
            textcolor      = color.white,
            style          = label.style_label_down,
            size           = size.tiny,
            text_font_family = font.family_default
        )
    
    // Lower wick percentage label (▼)
    if lower_wick > 0
        label.new(
            x              = x_mid,
            y              = or_low_v - 25,
            text           = "▼" + str.tostring(math.round(lower_pct)) + "%",
            color          = color.new(color.gray, 70),
            textcolor      = color.white,
            style          = label.style_label_up,
            size           = size.tiny,
            text_font_family = font.family_default
        )

// Block label visualization - show after OR classification if trade was blocked
if barstate.islastconfirmedhistory and show_block_labels and trade_blocked_today and not na(block_reason) and block_reason != "" and block_reason != "?"
    label.new(bar_index + 3, break_dir_v == 1 ? high + 15 : low - 15, "NO TRADE: " + block_reason,
              style=break_dir_v == 1 ? label.style_label_down : label.style_label_up, 
              color=color.orange, textcolor=color.white, size=size.small)

// ── SECTION O: INFO TABLE (GUARD 7 & 8) ──────────────────────────────────────

// GUARD 8 — var table declared outside if block (17 rows for new entries)
var table tbl = table.new(position.top_right, 2, 17,
                           bgcolor=color.new(color.black, 50),
                           border_color=color.white,
                           border_width=1)

// GUARD 7 — tbl_set must be top-level function
tbl_set(row, lbl, val, val_color) =>
    table.cell(tbl, 0, row, lbl, text_color=color.new(color.gray, 20), text_size=size.small)
    table.cell(tbl, 1, row, val, text_color=val_color, text_size=size.small)

// Helper function to get weekday block label
get_wd_block_info() =>
    bool blocked = (enable_thu_long_block and dayofweek(time, tz_input) == dayofweek.thursday) or
                   (enable_tue_short_block and dayofweek(time, tz_input) == dayofweek.tuesday) or
                   (enable_wed_long_block and dayofweek(time, tz_input) == dayofweek.wednesday) or
                   (enable_fri_long_block and dayofweek(time, tz_input) == dayofweek.friday)
    string lbl = "—"
    if enable_thu_long_block and dayofweek(time, tz_input) == dayofweek.thursday
        lbl := "THU long"
    else if enable_tue_short_block and dayofweek(time, tz_input) == dayofweek.tuesday
        lbl := "TUE short"
    else if enable_wed_long_block and dayofweek(time, tz_input) == dayofweek.wednesday
        lbl := "WED long"
    else if enable_fri_long_block and dayofweek(time, tz_input) == dayofweek.friday
        lbl := "FRI long"
    [blocked, lbl]

if barstate.islastconfirmedhistory  // NOT barstate.islast (GUARD 8)
    [wd_blocked_today, wd_block_label] = get_wd_block_info()
    tbl_set(0, "Regime",     str.tostring(regime_v),                                          color.white)
    tbl_set(1, "Pattern",    str.tostring(pattern_v),                                        color.white)
    tbl_set(2, "Score",      str.tostring(score_v) + "/5",                                   score_v >= min_score ? color.green : color.red)
    tbl_set(3, "OR Range",   str.tostring(or_range_v, "#.##") + " pts",                      color.white)
    tbl_set(4, "Clean Brk",  clean_break_act ? "YES ★" : "no",                               clean_break_act ? color.green : color.gray)
    tbl_set(5, "Max Exc",    str.tostring(max_fav_exc, "#.##") + " pts (" + 
                             str.tostring(not na(or_range_v) and or_range_v > 0 ? math.round(max_fav_exc / or_range_v * 100) : 0) + "%OR)", color.white)
    tbl_set(6, "Retouches",  str.tostring(retouch_cnt),                                      retouch_cnt >= retouch_reduce_at ? color.orange : color.white)
    tbl_set(7, "Entries",    str.tostring(day_entry_cnt) + "/" + str.tostring(max_entries_per_day), color.white)
    tbl_set(8, "Break Dir",  break_dir_v == 1 ? "UP" : break_dir_v == -1 ? "DOWN" : "NONE", color.white)
    tbl_set(9,  "Circuit Brk", enable_circuit_breaker ? (consec_losses >= max_consec_losses or daily_stop_hits >= max_daily_stops ? "PAUSED" : "active") : "off",
                             consec_losses >= max_consec_losses or daily_stop_hits >= max_daily_stops ? color.red : color.green)
    tbl_set(10, "Consec Losses", str.tostring(consec_losses) + "/" + str.tostring(max_consec_losses),
                             consec_losses >= 2 ? color.orange : color.white)
    tbl_set(11, "Day Stops",    str.tostring(daily_stop_hits) + "/" + str.tostring(max_daily_stops),
                             daily_stop_hits >= max_daily_stops ? color.red : color.white)
    tbl_set(12, "Break Bar",   not na(break_bar_v) ? str.tostring(break_bar_v) : "—", color.white)
    tbl_set(13, "Was Outside", was_outside ? "YES" : "no", color.white)
    tbl_set(14, "Day Locked",  day_locked_e1loss ? "YES (E1 loss)" : "no",
                              day_locked_e1loss ? color.red : color.green)
    tbl_set(15, "Day Block", wd_block_label, wd_blocked_today ? color.orange : color.gray)
    tbl_set(16, "Time Cap",    enable_entry_time_cap ? str.tostring(max_entry_hour) + ":" + (max_entry_min < 10 ? "0" + str.tostring(max_entry_min) : str.tostring(max_entry_min)) : "off",
                              color.white)

// ─────────────────────────────────────────────────────────────────────────────
// SECTION P — ALERT FORMAT TEST (ported from MNQ v5 Section 17)
// Fires every payload shape on the current live bar so you can inspect
// the exact JSON in Pipedream / webhook.site before going live.
//
// HOW TO USE:
//   1. Set alert_test_mode = true in the input panel, save the script
//   2. Watch your webhook viewer — all shapes arrive on the current live bar
//   3. Confirm price / stopPrice / takeProfit are JSON numbers (no quotes)
//   4. Set alert_test_mode = false, save again BEFORE trading live
//
// alert.freq_all is used here (not freq_once_per_bar) so every shape fires
// in the same bar. Production calls above use freq_once_per_bar.
// ─────────────────────────────────────────────────────────────────────────────

if barstate.islast and alert_test_mode and enable_traderspost_alerts
    // Entry shapes — long and short with realistic offset stops/TPs
    alert(buildEntryJson("buy",  "E0_ENTRY", close - 5.0, close + 10.0), alert.freq_all)
    alert(buildEntryJson("sell", "E1_ENTRY", close + 5.0, close - 10.0), alert.freq_all)
    // Exit shapes — one per close_all() exit type the script can produce
    alert(buildExitJson("TIME_STOP_EXIT"),      alert.freq_all)
    alert(buildExitJson("OPPOSITE_LEVEL_EXIT"), alert.freq_all)
    alert(buildExitJson("DEEP_EXIT"),           alert.freq_all)
    alert(buildExitJson("SESSION_END_EXIT"),    alert.freq_all)
